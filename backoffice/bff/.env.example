# Puerto del BFF (el backend real corre en 3000)
PORT=3001

# URL del backend real de Keru (zona no-pública: solo el BFF le pega)
KERU_API_URL=http://localhost:3000/api/v1

# Cookie de sesión (el JWT vive acá, httpOnly — el browser nunca lo ve en JS)
COOKIE_NAME=keru_bo_session
# En prod: true (requiere HTTPS)
COOKIE_SECURE=false

# Origen del front en desarrollo (Angular dev server) para CORS con credenciales
WEB_ORIGIN=http://localhost:4200
